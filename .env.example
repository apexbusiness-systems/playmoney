# PlayMoney — Environment Template
# NEVER commit real values. Copy to .env.local for local development only.
# GitHub/Cloudflare production values must live in GitHub Secrets or Cloudflare Secrets.
# See DEPLOY.md for setup details. This template does not indicate release readiness.

# ── Build-time public Vite vars (RLS-safe; exposed to browser bundles) ────────
# Required for production deploy builds. These must be the public Supabase URL
# and anon/publishable key only — never the service-role key.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key-here

# Optional production-build safety guard. Deploy CI sets this to true so builds
# fail instead of silently selecting MockApiClient when public Supabase config is
# missing. Leave unset/false for offline local development.
# VITE_PLAYMONEY_REQUIRE_SUPABASE_CONFIG=true

# ── Server/runtime Supabase vars (server-side adapters/scripts) ───────────────
# SUPABASE_URL is the same project URL without the VITE_ browser exposure prefix.
# SUPABASE_ANON_KEY / SUPABASE_PUBLISHABLE_KEY are still public/RLS-scoped keys,
# but are consumed by server-side scripts and runtime env readers.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key-here
# SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# ── Service-role / management secrets (server-only; NEVER prefix with VITE_) ──
SUPABASE_SERVICE_ROLE_KEY=ROTATE_ME_IN_SUPABASE_DASHBOARD
SUPABASE_TOKEN=ROTATE_ME_IN_SUPABASE_DASHBOARD

# ── Adapter secrets (server-only; set via wrangler secret put in production) ──
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
FLINKS_API_URL=https://your-flinks-instance.flinks.com
FLINKS_CLIENT_ID=REPLACE_ME
PLAID_CLIENT_ID=REPLACE_ME
PLAID_SECRET=REPLACE_ME
PLAID_ENV=sandbox
RESEND_API_KEY=
OUTBOUND_EMAIL_FROM=disputes@playmoney.icu

# ── Mode (default BUILT — never set to LIVE in source code) ───────────────────
# PLAYMONEY_MODE=BUILT
# Change to LIVE only via `wrangler secret put PLAYMONEY_MODE` after all gates are green.
