# PlayMoney — Environment Template
# NEVER commit real values. All secrets must live in Cloudflare Secrets or GitHub Secrets.
# Copy this file to .env.local for local development and fill in your values.
#
# Required secrets — set via `wrangler secret put <NAME>` for production:
#   SUPABASE_SERVICE_ROLE_KEY — bypasses RLS; rotate in Supabase dashboard (SECURITY-001)
#   SUPABASE_TOKEN            — Supabase management API token; rotate after any exposure
#
# See DEPLOY.md for full setup instructions.

# ── Public (RLS-safe, can be exposed to the browser via Vite) ─────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Server-only secrets (NEVER prefix with VITE_) ─────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=ROTATE_ME_IN_SUPABASE_DASHBOARD
SUPABASE_TOKEN=ROTATE_ME_IN_SUPABASE_DASHBOARD

# ── Adapter secrets (set via wrangler secret put in production) ───────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
FLINKS_API_URL=https://your-flinks-instance.flinks.com
FLINKS_CLIENT_ID=REPLACE_ME
PLAID_CLIENT_ID=REPLACE_ME
PLAID_SECRET=REPLACE_ME
PLAID_ENV=sandbox

# ── Mode (default BUILT — never set to LIVE in source code) ───────────────────
# PLAYMONEY_MODE=BUILT
# Change to LIVE only via `wrangler secret put PLAYMONEY_MODE` after all 10 gates are green.
